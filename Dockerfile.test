FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root

RUN apt-get update && apt-get install -y git zsh tmux vim nano curl ca-certificates dnsutils fzf direnv \
    && rm -rf /var/lib/apt/lists/*

COPY . /root/.dotfiles

# Install oh-my-zsh
RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

# Install zsh plugins
RUN git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-/root/.oh-my-zsh/custom}/plugins/zsh-autosuggestions \
    && git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-/root/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting \
    && git clone https://github.com/zsh-users/zsh-completions ${ZSH_CUSTOM:-/root/.oh-my-zsh/custom}/plugins/zsh-completions \
    && git clone https://github.com/MichaelAquilina/zsh-you-should-use.git ${ZSH_CUSTOM:-/root/.oh-my-zsh/custom}/plugins/you-should-use

# Install CLI tools
RUN curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh \
    && git clone https://github.com/ahmetb/kubectx /opt/kubectx \
    && ln -fs /opt/kubectx/kubectx /usr/local/bin/kubectx \
    && ln -fs /opt/kubectx/kubens /usr/local/bin/kubens

# Symlink configs
RUN ln -fs /root/.dotfiles/zsh/.zshrc /root/.zshrc \
    && ln -fs /root/.dotfiles/tmux/.tmux.conf /root/.tmux.conf

# Install uv and Python
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"
RUN uv python install 3.14

# Install Python packages
RUN cd /root/.dotfiles/python && uv sync

# Install TPM
RUN mkdir -p /root/.tmux/plugins \
    && git clone https://github.com/tmux-plugins/tpm /root/.tmux/plugins/tpm

# Verify everything works
RUN echo "=== Verification ===" \
    && echo "--- zsh ---" && zsh --version \
    && echo "--- tmux ---" && tmux -V \
    && echo "--- uv ---" && uv --version \
    && echo "--- python ---" && uv run --project /root/.dotfiles/python python --version \
    && echo "--- zshrc syntax ---" && zsh -n /root/.zshrc \
    && echo "--- aliases ---" && zsh -c 'source /root/.zshrc && alias ll && alias dk && alias kc' \
    && echo "--- tools ---" && fzf --version && zoxide --version && which kubectx && which kubens && direnv --version \
    && echo "--- tmux config syntax ---" && tmux -f /root/.tmux.conf start-server \; kill-server \
    && echo "=== All checks passed ==="

CMD ["zsh"]
